<!DOCTYPE html>
<html>
<head>
    <title>System Information</title>
</head>
<body>
    <h1>System Information for {{ ansible_facts.hostname }}</h1>
    <ul>
        <li><strong>IP Address:</strong> {{ ansible_facts.default_ipv4.address }}</li>
        <li><strong>CPU Info:</strong> {{ ansible_facts.processor | join(', ') }}</li>
        <li><strong>RAM (MB):</strong> {{ ansible_facts.memtotal_mb }}</li>
        {% if ansible_facts.devices %}
            {% set first_disk = ansible_facts.devices | first %}
            <li><strong>First HDD Size:</strong> {{ ansible_facts.devices[first_disk].size }}</li>
        {% else %}
            <li><strong>First HDD Size:</strong> Not available</li>
        {% endif %}
        <li><strong>OS:</strong> {{ ansible_facts.distribution }} {{ ansible_facts.distribution_version }}</li>
    </ul>
    <p>Generated on: {{ ansible_date_time.iso8601 }}</p>
</body>
</html>
